{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests",
    "clean": "rm -rf dist .turbo node_modules",
    "check-types": "tsc --noEmit",
    "migration:create": "typeorm migration:create",
    "migration:generate": "typeorm migration:generate -d ./src/database/data-source.ts",
    "migration:run": "typeorm migration:run -d ./src/database/data-source.ts",
    "migration:revert": "typeorm migration:revert -d ./src/database/data-source.ts",
    "schema:sync": "typeorm schema:sync -d ./src/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register ./src/seeds/run.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/typeorm": "^11.0.3",
    "@repo/config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
