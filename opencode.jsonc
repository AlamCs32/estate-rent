{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mui-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@mui/mcp@latest"],
      "enabled": true
    }
  },
  "instructions": [
    ".agents/docs/AGENTS.md",
    ".agents/docs/RULES.md",
    ".agents/docs/ARCHITECTURE.md",
    ".agents/docs/COMMANDS.md",
    ".agents/docs/CODING_STANDARDS.md",
    ".agents/docs/API_GUIDELINES.md",
    ".agents/docs/DATABASE_GUIDELINES.md",
    ".agents/docs/FRONTEND_GUIDELINES.md",
    ".agents/docs/SECURITY.md",
    ".agents/docs/STACK.md",
    ".agents/docs/TESTING.md",
    ".github/instructions/mui.md"
  ]
}
